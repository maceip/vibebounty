{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BugBountyTriageVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "disposition",
    "severity_estimate",
    "is_duplicate_risk",
    "reasoning",
    "questions_for_researcher",
    "confidence"
  ],
  "properties": {
    "disposition": {
      "type": "string",
      "enum": [
        "valid_impactful",
        "valid_low",
        "corroborated_surge",
        "likely_duplicate",
        "out_of_scope",
        "theoretical_no_poc",
        "self_inflicted",
        "accepted_risk",
        "slop"
      ]
    },
    "severity_estimate": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "none"]
    },
    "is_duplicate_risk": { "type": "boolean" },
    "reasoning": {
      "type": "string",
      "description": "Concise justification grounded in the submission's specifics."
    },
    "questions_for_researcher": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Clarifying questions that would change the verdict; empty if none."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "used_external_corroboration": {
      "type": "boolean",
      "description": "True if an EXTERNAL CORROBORATION block influenced this verdict."
    }
  }
}
